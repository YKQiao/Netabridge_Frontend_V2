# =============================================================================
# NetaBridge Frontend - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values

# Backend API URL (handles OAuth and all API calls)
NEXT_PUBLIC_API_URL=http://localhost:8000

# API Key (must match backend API_KEY)
NEXT_PUBLIC_API_KEY=your-api-key-here

# =============================================================================
# Optional: Dev Mode Detection
# =============================================================================
# If ENTRA_CLIENT_ID is empty or placeholder, frontend shows "Dev Mode" indicator
# and allows passwordless login via /api/v1/auth/dev/login

NEXT_PUBLIC_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
