# =============================================================================
# NetaBridge Frontend - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# API Key (must match backend API_KEY)
NEXT_PUBLIC_API_KEY=your-api-key-here

# =============================================================================
# Microsoft Entra ID Configuration
# =============================================================================

# Your App Registration Client ID
NEXT_PUBLIC_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Your Tenant ID (for regular Entra ID)
NEXT_PUBLIC_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000

# Redirect URI (must match App Registration)
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000

# =============================================================================
# For Entra External ID (B2C) - Optional
# =============================================================================
# If using B2C for external users, set these instead of TENANT_ID

# NEXT_PUBLIC_B2C_TENANT_NAME=netabridgeauth
# NEXT_PUBLIC_B2C_POLICY_NAME=B2C_1_signupsignin
